<Application x:Class="FocusTime.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:FocusTime.App.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Converters -->
            <converters:InverseBoolConverter x:Key="InverseBoolConverter"/>
            <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
            <converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
            <converters:BoolToCheckmarkConverter x:Key="BoolToCheckmarkConverter"/>
            <converters:NotNullConverter x:Key="NotNullConverter"/>
            <converters:TabBackgroundConverter x:Key="TabBackgroundConverter"/>
            <converters:TabFontWeightConverter x:Key="TabFontWeightConverter"/>
            
            <!-- Color scheme -->
            <SolidColorBrush x:Key="PrimaryBrush" Color="#2196F3"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#4CAF50"/>
            <SolidColorBrush x:Key="DangerBrush" Color="#F44336"/>
            <SolidColorBrush x:Key="BackgroundBrush" Color="#FAFAFA"/>
            <SolidColorBrush x:Key="SurfaceBrush" Color="#FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimaryBrush" Color="#212121"/>
            <SolidColorBrush x:Key="TextSecondaryBrush" Color="#757575"/>
            
            <!-- Button style -->
            <Style TargetType="Button">
                <Setter Property="Padding" Value="12,6"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="FontSize" Value="14"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>

            <!-- TextBox style -->
            <Style TargetType="TextBox">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>

            <!-- ComboBox style -->
            <Style TargetType="ComboBox">
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="FontSize" Value="14"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
