<Window x:Class="FocusTime.App.Views.DistractionPromptDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bạn đang làm gì?"
        Width="400"
        Height="350"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#1E1E1E"
        Foreground="White"
        Topmost="True">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Bạn đang làm gì?"
                   FontSize="18"
                   FontWeight="Bold"
                   Margin="0,0,0,15"/>

        <TextBlock Grid.Row="1"
                   x:Name="AppNameText"
                   Text="Ứng dụng: ..."
                   FontSize="12"
                   Opacity="0.7"
                   Margin="0,0,0,20"/>

        <TextBlock Grid.Row="2"
                   Text="Mục đích:"
                   FontSize="14"
                   FontWeight="SemiBold"
                   Margin="0,0,0,8"/>

        <Grid Grid.Row="3" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Button Grid.Row="0" Grid.Column="0" Content="🖥️ Công việc" Tag="Work" Click="Purpose_Click" 
                    Margin="0,0,5,5" Height="40" Background="#0078D4" BorderThickness="0" Cursor="Hand"/>
            <Button Grid.Row="0" Grid.Column="1" Content="📋 Việc cần thiết" Tag="Needed" Click="Purpose_Click" 
                    Margin="5,0,0,5" Height="40" Background="#107C10" BorderThickness="0" Cursor="Hand"/>
            <Button Grid.Row="1" Grid.Column="0" Content="☕ Nghỉ giải lao" Tag="Break" Click="Purpose_Click" 
                    Margin="0,5,5,0" Height="40" Background="#CA5010" BorderThickness="0" Cursor="Hand"/>
            <Button Grid.Row="1" Grid.Column="1" Content="🌐 Đang lạc" Tag="Wandering" Click="Purpose_Click" 
                    Margin="5,5,0,0" Height="40" Background="#D13438" BorderThickness="0" Cursor="Hand"/>
        </Grid>

        <StackPanel Grid.Row="4" x:Name="DurationPanel" Visibility="Collapsed" Margin="0,10,0,0">
            <TextBlock Text="Thời l
ượng dự kiến:"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8"/>
            <UniformGrid Columns="4" Rows="1">
                <Button Content="1m" Tag="1" Click="Duration_Click" Margin="0,0,3,0" Height="35" Background="#2D2D30" BorderThickness="0" Cursor="Hand"/>
                <Button Content="3m" Tag="3" Click="Duration_Click" Margin="3,0,3,0" Height="35" Background="#2D2D30" BorderThickness="0" Cursor="Hand"/>
                <Button Content="5m" Tag="5" Click="Duration_Click" Margin="3,0,3,0" Height="35" Background="#2D2D30" BorderThickness="0" Cursor="Hand"/>
                <Button Content="10m" Tag="10" Click="Duration_Click" Margin="3,0,0,0" Height="35" Background="#2D2D30" BorderThickness="0" Cursor="Hand"/>
            </UniformGrid>
        </StackPanel>
    </Grid>
</Window>
