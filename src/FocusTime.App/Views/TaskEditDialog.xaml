<Window x:Class="FocusTime.App.Views.TaskEditDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Task Editor" Height="550" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    
    <Grid Background="{StaticResource BackgroundBrush}" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Form Fields -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Title -->
                <TextBlock Text="Title *" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBox x:Name="TitleTextBox" TextWrapping="Wrap" Height="60" VerticalContentAlignment="Top"/>

                <!-- Estimate -->
                <TextBlock Text="Estimate (minutes)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBox x:Name="EstimateTextBox" Text=""/>

                <!-- Status -->
                <TextBlock Text="Status" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <ComboBox x:Name="StatusComboBox" SelectedIndex="0">
                    <ComboBoxItem Content="Todo"/>
                    <ComboBoxItem Content="Doing"/>
                    <ComboBoxItem Content="Done"/>
                    <ComboBoxItem Content="Partial"/>
                    <ComboBoxItem Content="Blocked"/>
                </ComboBox>

                <!-- Priority -->
                <TextBlock Text="Priority" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <ComboBox x:Name="PriorityComboBox" SelectedIndex="1">
                    <ComboBoxItem Content="1 - High" Tag="1"/>
                    <ComboBoxItem Content="2 - Medium" Tag="2"/>
                    <ComboBoxItem Content="3 - Low" Tag="3"/>
                </ComboBox>

                <!-- Tags -->
                <TextBlock Text="Tags (comma-separated)" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBox x:Name="TagsTextBox" Text="" 
                         ToolTip="Enter tags separated by commas, e.g. work, urgent, frontend"/>

                <!-- Note -->
                <TextBlock Text="Note" FontWeight="SemiBold" Margin="0,12,0,4"/>
                <TextBox x:Name="NoteTextBox" TextWrapping="Wrap" Height="80" 
                         VerticalContentAlignment="Top" AcceptsReturn="True"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Action Buttons -->
        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <Button Grid.Column="0" Content="Cancel" Click="Cancel_Click" 
                    Margin="0,0,8,0"/>
            <Button Grid.Column="1" Content="Save" Click="Save_Click"
                    Background="{StaticResource AccentBrush}" Foreground="White" 
                    Margin="8,0,0,0"/>
        </Grid>
    </Grid>
</Window>
