<Window x:Class="FocusTime.App.Views.NotificationPopup"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notification" 
        Width="400" Height="150"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent"
        Topmost="True"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual">
    
    <Border Background="#FFFFFF" BorderBrush="{StaticResource PrimaryBrush}" 
            BorderThickness="2" CornerRadius="8" Padding="20">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.3" BlurRadius="15" ShadowDepth="3"/>
        </Border.Effect>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <TextBlock Grid.Row="0" x:Name="TitleText" 
                       Text="Notification" 
                       FontSize="18" FontWeight="Bold" 
                       Foreground="{StaticResource PrimaryBrush}" 
                       Margin="0,0,0,8"/>

            <!-- Message -->
            <TextBlock Grid.Row="1" x:Name="MessageText" 
                       Text="Message content here" 
                       FontSize="14" 
                       TextWrapping="Wrap" 
                       Foreground="{StaticResource TextPrimaryBrush}"
                       VerticalAlignment="Center"/>

            <!-- Close Button -->
            <Button Grid.Row="2" Content="OK" 
                    Width="80" Height="32" 
                    HorizontalAlignment="Right" 
                    Background="{StaticResource AccentBrush}" 
                    Foreground="White"
                    Click="CloseButton_Click" 
                    Margin="0,12,0,0"/>
        </Grid>
    </Border>
</Window>
